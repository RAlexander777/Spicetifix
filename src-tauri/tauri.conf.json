{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "http://127.0.0.1:8765",
    "distDir": "../web"
  },
  "package": {
    "productName": "Spicetifix",
    "version": "0.2.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://127.0.0.1:8765/*"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.spicetifix.app",
      "icon": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "SPICETIFIX // TAURI SHELL",
        "width": 780,
        "height": 720,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
